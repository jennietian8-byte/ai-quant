name: TASK4 Daily Data + Deploy

on:
  workflow_dispatch:
  schedule:
    - cron: "15 1 * * *"

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: task4-pages
  cancel-in-progress: true

jobs:
  deploy:
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Configure Pages
        uses: actions/configure-pages@v5

      - name: Upload TASK4 static site
        uses: actions/upload-pages-artifact@v3
        with:
          path: task4/site

      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
